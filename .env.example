# Database connection string
# For local SQLite: "file:./dev.db"
# For Vercel/Production: Use a PostgreSQL/MySQL connection string (e.g. from Neon, Supabase, etc.) and update prisma/schema.prisma provider if needed.
DATABASE_URL="file:./dev.db"

# JWT Secret for security session cookies
JWT_SECRET="replace-with-a-secure-random-secret-key"
